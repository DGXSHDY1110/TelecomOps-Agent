# ============================================
# TelecomOps-Agent Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telecomops
POSTGRES_USER=telecomops
POSTGRES_PASSWORD=changeme

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# LLM (future milestone)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
# LLM_BASE_URL=

# Embedding (future milestone)
# EMBEDDING_MODEL=text-embedding-3-small

# Vector Store (future milestone)
# VECTOR_STORE_TYPE=faiss
# VECTOR_STORE_PATH=data/vector_store

# Logging
LOG_LEVEL=INFO
